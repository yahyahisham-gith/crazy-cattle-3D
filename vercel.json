{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "status": 301,
      "headers": { "Location": "/website/2/3/" }
    },
    {
      "src": "/(?!website/2/3/)(.*)",
      "status": 301,
      "headers": { "Location": "/website/2/3/$1" }
    },
    {
      "src": "/website/2/3/(.*)",
      "dest": "/website/2/3/$1"
    }
  ]
}